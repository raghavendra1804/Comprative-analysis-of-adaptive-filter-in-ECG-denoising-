input_filename = [];

% Default sampling frequency (used if file does not contain Fs)
defaultFs = 360;

% Adaptive filter length
filterLength = 16;

% Enable / disable algorithms
run_LMS    = true;
run_NLMS   = true;
run_PNLMS  = true;
run_IPNLMS = true;
run_RLS    = true;
run_Kalman = true;
run_EEMD   = true;

% EEMD parameters
eemd_ensembles = 20;
eemd_noise_level_factor = 0.2;

% Composite score weights (must sum to 1 ideally)
w_snr  = 0.30;
w_prd  = 0.25;
w_mse  = 0.15;
w_corr = 0.20;
w_time = 0.10;

%% ======================================================

%% ----------------- Load data -----------------
if isempty(input_filename)
    use_synthetic = true;
else
    use_synthetic = false;
end

if ~use_synthetic
    try
        [ecg_noisy, acc, Fs, time_vec, ecg_clean_user] = my_load_ecg_acc(input_filename, defaultFs);
        fprintf('Loaded data file: %s (N=%d, Fs=%g Hz)\n', input_filename, length(ecg_noisy), Fs);
        t = time_vec(:);
        if isempty(t), t = (0:length(ecg_noisy)-1)'/Fs; end
    catch ME
        warning('Loading failed (%s). Falling back to synthetic generator.\nError: %s', input_filename, ME.message);
        use_synthetic = true;
    end
end

if use_synthetic
    Fs = defaultFs;
    dur = 12; t = (0:1/Fs:dur-1/Fs)'; 
    fprintf('Using synthetic ECG generator (Fs=%g Hz, dur=%g s)\n', Fs, dur);
    [ecg_clean_user, ecg_noisy, acc, t] = my_synthetic_ecg_with_motion(Fs, dur);
    ecg_clean_user = ecg_clean_user(:);
end

N = length(ecg_noisy);
ecg_noisy = ecg_noisy(:);
acc = acc(:);
if length(acc) ~= N
    acc = my_resample_vector(acc, N);
end

% If user provided a clean reference, keep it; otherwise empty (we'll build surrogate)
if exist('ecg_clean_user','var') && ~isempty(ecg_clean_user)
    ecg_clean = ecg_clean_user(:);
    have_clean = true;
    if length(ecg_clean) ~= N
        % Truncate or resample if needed (take min length)
        Lmin = min(length(ecg_clean), N);
        ecg_clean = ecg_clean(1:Lmin); ecg_noisy = ecg_noisy(1:Lmin); acc = acc(1:Lmin); t = t(1:Lmin); N = Lmin;
    end
else
    ecg_clean = []; have_clean = false;
end

% If no clean reference, create surrogate clean (bandpass + median)
if ~have_clean
    fprintf('No ground-truth clean ECG found. Creating surrogate clean for metric calculation.\n');
    surrogate = my_bandpass(ecg_noisy, [0.5 40], Fs);
    surrogate = medfilt1(surrogate, round(0.06*Fs)); % median smoothing approx 60ms
    ecg_clean = surrogate;
    surrogate_flag = true;
else
    surrogate_flag = false;
end

% remove DC from acc reference
acc = acc - mean(acc);

%% ---------- Metric helpers ----------
snr_calc = @(clean, est) 10*log10( sum(clean.^2) / (sum((est - clean).^2) + eps) );
mse_calc = @(clean, est) mean((clean - est).^2);
prd_calc = @(clean, est) sqrt(sum((clean - est).^2) / (sum(clean.^2) + eps)) * 100;
corr_calc = @(clean, est) corr(clean, est);

baseline_snr = snr_calc(ecg_clean, ecg_noisy);

%% ---------- Prepare results container ----------
results = struct();
results.Original.clean = ecg_clean;
results.Original.noisy = ecg_noisy;
results.Original.Fs = Fs;
results.Original.SNR_dB = baseline_snr;
results.Original.MSE = mse_calc(ecg_clean, ecg_noisy);
results.Original.PRD = prd_calc(ecg_clean, ecg_noisy);
results.Original.CORR = corr_calc(ecg_clean, ecg_noisy);
results.Original.TimeSec = 0;
results.Info.surrogate_used = surrogate_flag;

d = ecg_noisy;
x_ref = acc;
L = filterLength;

%% ---------------- Run algorithms ----------------
fprintf('Running algorithms (this may take a few seconds)...\n');

% LMS
if run_LMS
    tic;
    mu = 0.005;
    [w_lms, y_lms, e_lms] = my_lms_adaptive(d, x_ref, L, mu);
    t_lms = toc;
    results.LMS.y = y_lms; results.LMS.time = t_lms;
    results.LMS.SNR_dB = snr_calc(ecg_clean, y_lms);
    results.LMS.SNRimprov_dB = results.LMS.SNR_dB - baseline_snr;
    results.LMS.MSE = mse_calc(ecg_clean, y_lms);
    results.LMS.PRD = prd_calc(ecg_clean, y_lms);
    results.LMS.CORR = corr_calc(ecg_clean, y_lms);
end

% NLMS
if run_NLMS
    tic;
    mu_n = 0.8; eps_nlms = 1e-6;
    [y_nlms, w_nlms] = my_nlms_adaptive(d, x_ref, L, mu_n, eps_nlms);
    t_nlms = toc;
    results.NLMS.y = y_nlms; results.NLMS.time = t_nlms;
    results.NLMS.SNR_dB = snr_calc(ecg_clean, y_nlms);
    results.NLMS.SNRimprov_dB = results.NLMS.SNR_dB - baseline_snr;
    results.NLMS.MSE = mse_calc(ecg_clean, y_nlms);
    results.NLMS.PRD = prd_calc(ecg_clean, y_nlms);
    results.NLMS.CORR = corr_calc(ecg_clean, y_nlms);
end

% PNLMS
if run_PNLMS
    tic;
    mu_p = 0.8; rho = 0.01; delta = 1e-3;
    [y_pnlms, w_pnlms] = my_pnlms_adaptive(d, x_ref, L, mu_p, rho, delta);
    t_pnlms = toc;
    results.PNLMS.y = y_pnlms; results.PNLMS.time = t_pnlms;
    results.PNLMS.SNR_dB = snr_calc(ecg_clean, y_pnlms);
    results.PNLMS.SNRimprov_dB = results.PNLMS.SNR_dB - baseline_snr;
    results.PNLMS.MSE = mse_calc(ecg_clean, y_pnlms);
    results.PNLMS.PRD = prd_calc(ecg_clean, y_pnlms);
    results.PNLMS.CORR = corr_calc(ecg_clean, y_pnlms);
end

% IPNLMS
if run_IPNLMS
    tic;
    mu_ip = 0.8; alpha = 0.0;
    [y_ipnlms, w_ipnlms] = my_ipnlms_adaptive(d, x_ref, L, mu_ip, alpha, rho, delta);
    t_ipnlms = toc;
    results.IPNLMS.y = y_ipnlms; results.IPNLMS.time = t_ipnlms;
    results.IPNLMS.SNR_dB = snr_calc(ecg_clean, y_ipnlms);
    results.IPNLMS.SNRimprov_dB = results.IPNLMS.SNR_dB - baseline_snr;
    results.IPNLMS.MSE = mse_calc(ecg_clean, y_ipnlms);
    results.IPNLMS.PRD = prd_calc(ecg_clean, y_ipnlms);
    results.IPNLMS.CORR = corr_calc(ecg_clean, y_ipnlms);
end

% RLS
if run_RLS
    tic;
    lambda = 0.99; delta_rls = 0.1;
    [y_rls, w_rls] = my_rls_adaptive(d, x_ref, L, lambda, delta_rls);
    t_rls = toc;
    results.RLS.y = y_rls; results.RLS.time = t_rls;
    results.RLS.SNR_dB = snr_calc(ecg_clean, y_rls);
    results.RLS.SNRimprov_dB = results.RLS.SNR_dB - baseline_snr;
    results.RLS.MSE = mse_calc(ecg_clean, y_rls);
    results.RLS.PRD = prd_calc(ecg_clean, y_rls);
    results.RLS.CORR = corr_calc(ecg_clean, y_rls);
end

% Kalman
if run_Kalman
    tic;
    q = 1e-5; rvar = 1e-3;
    [y_kalman, w_kalman] = my_kalman_adaptive(d, x_ref, L, q, rvar);
    t_kalman = toc;
    results.Kalman.y = y_kalman; results.Kalman.time = t_kalman;
    results.Kalman.SNR_dB = snr_calc(ecg_clean, y_kalman);
    results.Kalman.SNRimprov_dB = results.Kalman.SNR_dB - baseline_snr;
    results.Kalman.MSE = mse_calc(ecg_clean, y_kalman);
    results.Kalman.PRD = prd_calc(ecg_clean, y_kalman);
    results.Kalman.CORR = corr_calc(ecg_clean, y_kalman);
end

% EEMD-style denoiser
if run_EEMD
    tic;
    noise_level = eemd_noise_level_factor * std(ecg_noisy);
    y_eemd = my_simple_eemd_denoise(ecg_noisy, Fs, eemd_ensembles, noise_level);
    t_eemd = toc;
    results.EEMD.y = y_eemd; results.EEMD.time = t_eemd;
    results.EEMD.SNR_dB = snr_calc(ecg_clean, y_eemd);
    results.EEMD.SNRimprov_dB = results.EEMD.SNR_dB - baseline_snr;
    results.EEMD.MSE = mse_calc(ecg_clean, y_eemd);
    results.EEMD.PRD = prd_calc(ecg_clean, y_eemd);
    results.EEMD.CORR = corr_calc(ecg_clean, y_eemd);
end

%% ---------------- Build comparison table ----------------
% Methods to include (Original + those computed)
methodList = {'Original','LMS','NLMS','PNLMS','IPNLMS','RLS','Kalman','EEMD'};
rows = {};
SNR_dB = []; SNR_improv = []; MSEv = []; PRDv = []; CORRv = []; Timev = [];

for i = 1:length(methodList)
    m = methodList{i};
    rows{end+1} = m; %#ok<SAGROW>
    if strcmp(m,'Original')
        SNR_dB(end+1) = results.Original.SNR_dB; %#ok<SAGROW>
        SNR_improv(end+1) = 0; %#ok<SAGROW>
        MSEv(end+1) = results.Original.MSE; %#ok<SAGROW>
        PRDv(end+1) = results.Original.PRD; %#ok<SAGROW>
        CORRv(end+1) = results.Original.CORR; %#ok<SAGROW>
        Timev(end+1) = results.Original.TimeSec; %#ok<SAGROW>
    else
        if isfield(results, m)
            SNR_dB(end+1) = results.(m).SNR_dB; %#ok<SAGROW>
            SNR_improv(end+1) = results.(m).SNRimprov_dB; %#ok<SAGROW>
            MSEv(end+1) = results.(m).MSE; %#ok<SAGROW>
            PRDv(end+1) = results.(m).PRD; %#ok<SAGROW>
            CORRv(end+1) = results.(m).CORR; %#ok<SAGROW>
            Timev(end+1) = results.(m).time; %#ok<SAGROW>
        else
            SNR_dB(end+1) = NaN; SNR_improv(end+1) = NaN; MSEv(end+1) = NaN;
            PRDv(end+1) = NaN; CORRv(end+1) = NaN; Timev(end+1) = NaN;
        end
    end
end

compTable = table(SNR_dB.', SNR_improv.', MSEv.', PRDv.', CORRv.', Timev.', 'RowNames', rows, ...
    'VariableNames', {'SNR_dB','SNR_improv_dB','MSE','PRD_percent','CORR','TimeSec'});

fprintf('\nComparison table (SNR in dB, PRD in %%):\n');
disp(compTable);

% Save comparison table
try
    writetable(compTable, 'comparison_table.csv', 'WriteRowNames', true);
    fprintf('Saved comparison_table.csv\n');
catch
    warning('Could not save comparison_table.csv');
end

%% ---------------- Ranking (composite score) ----------------
% Exclude Original baseline from ranking
alg_names = compTable.Properties.RowNames;
isBaseline = strcmp(alg_names,'Original');
alg_names_rank = alg_names(~isBaseline);

SNR_improv_arr = compTable.SNR_improv_dB(~isBaseline);
PRD_arr = compTable.PRD_percent(~isBaseline);
MSE_arr = compTable.MSE(~isBaseline);
CORR_arr = compTable.CORR(~isBaseline);
Time_arr = compTable.TimeSec(~isBaseline);

% Normalize to 0..1 (higher-is-better)
norm01 = @(v) (v - min(v)) ./ (max(v) - min(v) + eps);
s_snr = norm01(SNR_improv_arr);
s_prd = 1 - norm01(PRD_arr);    % invert (lower better)
s_mse = 1 - norm01(MSE_arr);
s_corr = norm01(CORR_arr);
s_time = 1 - norm01(Time_arr);

composite = w_snr*s_snr + w_prd*s_prd + w_mse*s_mse + w_corr*s_corr + w_time*s_time;

T_rank = table(alg_names_rank, SNR_improv_arr, PRD_arr, MSE_arr, CORR_arr, Time_arr, composite, ...
    'VariableNames', {'Algorithm','SNR_improv_dB','PRD_percent','MSE','CORR','TimeSec','CompositeScore'});

T_rank_sorted = sortrows(T_rank, 'CompositeScore', 'descend');
T_rank_sorted = addvars(T_rank_sorted, (1:height(T_rank_sorted))','Before','Algorithm','NewVariableNames','Rank');

fprintf('\nAlgorithm ranking (best -> least) based on composite score:\n');
disp(T_rank_sorted);

% Save ranking table
try
    writetable(T_rank_sorted, 'ranking_table.csv');
    fprintf('Saved ranking_table.csv\n');
catch
    warning('Could not save ranking_table.csv');
end

% Save full results
save('ecg_denoise_results_final.mat','results','compTable','T_rank_sorted','t','Fs','ecg_clean','ecg_noisy','acc');

%% ---------------- Plots ----------------
% Overview
figure('Name','ECG overview','Units','normalized','Position',[0.05 0.1 0.9 0.8]);
subplot(4,1,1); plot(t, ecg_clean); title('Clean ECG (ground truth or surrogate)'); xlabel('Time (s)');
subplot(4,1,2); plot(t, ecg_noisy); title('Noisy ECG (input)'); xlabel('Time (s)');
ax3 = subplot(4,1,3); hold on; if isfield(results,'RLS'); plot(t, results.RLS.y); end; title('Denoised example (RLS)'); xlabel('Time (s)');
ax4 = subplot(4,1,4); hold on; if isfield(results,'Kalman'); plot(t, results.Kalman.y); end; title('Denoised example (Kalman)'); xlabel('Time (s)');
linkaxes([ax3 ax4],'x');
saveas(gcf,'ecg_overview_final.png');

% Zoomed section
zoomW = round(1*Fs); startInd = round(3*Fs);
if startInd+zoomW-1 > length(t), startInd = 1; end
inds = startInd:(startInd+zoomW-1);
figure('Name','Zoomed comparison final','Units','normalized','Position',[0.1 0.15 0.8 0.6]);
plot(t(inds), ecg_clean(inds),'k','LineWidth',1.2); hold on;
plot(t(inds), ecg_noisy(inds),'Color',[0.7 0.7 0.7]);
legendEntries = {'clean','noisy'};
if isfield(results,'LMS'), plot(t(inds), results.LMS.y(inds)); legendEntries{end+1} = 'LMS'; end
if isfield(results,'NLMS'), plot(t(inds), results.NLMS.y(inds)); legendEntries{end+1} = 'NLMS'; end
if isfield(results,'PNLMS'), plot(t(inds), results.PNLMS.y(inds)); legendEntries{end+1} = 'PNLMS'; end
if isfield(results,'IPNLMS'), plot(t(inds), results.IPNLMS.y(inds)); legendEntries{end+1} = 'IPNLMS'; end
if isfield(results,'RLS'), plot(t(inds), results.RLS.y(inds)); legendEntries{end+1} = 'RLS'; end
if isfield(results,'Kalman'), plot(t(inds), results.Kalman.y(inds)); legendEntries{end+1} = 'Kalman'; end
if isfield(results,'EEMD'), plot(t(inds), results.EEMD.y(inds),'--'); legendEntries{end+1} = 'EEMD'; end
legend(legendEntries,'Location','bestoutside');
title('Zoomed (1s) comparison (final)'); xlabel('Time (s)');
saveas(gcf,'ecg_zoomed_comparison_final.png');

% Composite score bar
figure('Name','Algorithm composite scores','Units','normalized','Position',[0.2 0.2 0.6 0.4]);
barh(flip(composite)); hold on;
yticks(1:length(composite));
yticklabels(flip(alg_names_rank));
xlabel('Composite score (higher is better)');
title('Algorithm ranking (higher = better)');
grid on;
saveas(gcf,'algorithm_ranking_final.png');

