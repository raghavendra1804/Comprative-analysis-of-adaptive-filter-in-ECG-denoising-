function [ecg, acc, Fs_out, time_vec, clean_ref] = my_load_ecg_acc(filename, defaultFs)
    % loads ecg and acc (and optional clean reference) from .mat, .csv, .txt
    [~,~,ext] = fileparts(filename);
    Fs_out = defaultFs; time_vec = []; ecg = []; acc = []; clean_ref = [];
    switch lower(ext)
        case '.mat'
            S = load(filename);
            vars = fieldnames(S);
            % try common variable names
            cand_ecg = {'ecg','ecg_raw','ecg_noisy','signal','lead1','leadI'};
            cand_acc = {'acc','accel','accel_z','accel_x','acc_x','accelerometer'};
            cand_fs = {'Fs','fs','sampling_rate'};
            for i=1:length(cand_ecg), if isfield(S,cand_ecg{i}), ecg = S.(cand_ecg{i}); end; end
            for i=1:length(cand_acc), if isfield(S,cand_acc{i}), acc = S.(cand_acc{i}); end; end
            for i=1:length(cand_fs), if isfield(S,cand_fs{i}), Fs_out = S.(cand_fs{i}); end; end
            if isfield(S,'time'), time_vec = S.time; end
            if isfield(S,'t'), time_vec = S.t; end
            % optional clean reference
            if isfield(S,'ecg_clean'), clean_ref = S.ecg_clean; end
            if isfield(S,'clean'), clean_ref = S.clean; end
            % fallback: pick first numeric vector as ecg and second as acc
            if isempty(ecg) || isempty(acc)
                numericVars = {};
                for i=1:length(vars)
                    v = S.(vars{i});
                    if isnumeric(v) && isvector(v)
                        numericVars{end+1} = vars{i}; %#ok<AGROW>
                    end
                end
                if isempty(ecg) && ~isempty(numericVars), ecg = S.(numericVars{1}); end
                if isempty(acc) && numel(numericVars)>=2, acc = S.(numericVars{2}); end
            end
        case '.csv'
            T = readtable(filename);
            varnames = T.Properties.VariableNames;
            if any(strcmpi(varnames,'time')), time_vec = T.time; end
            if any(strcmpi(varnames,'ecg')), ecg = T.ecg; end
            if any(strcmpi(varnames,'acc')), acc = T.acc; end
            if isempty(ecg) || isempty(acc)
                % pick first two numeric columns
                numericCols = varfun(@isnumeric, T, 'OutputFormat','uniform');
                idx = find(numericCols);
                if numel(idx) >= 2
                    ecg = T{:,idx(1)}; acc = T{:,idx(2)};
                end
            end
        case '.txt'
            M = dlmread(filename);
            if size(M,2) >= 2
                ecg = M(:,1); acc = M(:,2);
                if size(M,2) >= 3
                    time_vec = M(:,3);
                    Fs_out = 1/mean(diff(time_vec));
                end
            end
        otherwise
            error('Unsupported file type: %s', ext);
    end
    if isempty(ecg)
        error('ECG signal not found in file. Make sure variable/column name includes ''ecg'' or provide file with ecg and acc.');
    end
    if isempty(acc)
        warning('Accelerometer not found. Reference-based adaptive methods may perform poorly.');
        acc = zeros(size(ecg));
    end
    ecg = double(ecg(:)); acc = double(acc(:));
    if isempty(time_vec)
        time_vec = (0:length(ecg)-1)'/Fs_out;
    end
end

function y = my_resample_vector(x, targetLen)
    % simple resample by linear interpolation to target length
    oldLen = length(x);
    if oldLen == targetLen, y = x; return; end
    xi = linspace(1, oldLen, targetLen);
    y = interp1(1:oldLen, x(:), xi(:), 'linear', 'extrap');
end

function [ecg_clean, ecg_noisy, acc, t] = my_synthetic_ecg_with_motion(Fs, dur)

    % Load real ECG dataset
   D = readmatrix('ecgdata.csv');
    raw_ecg = D(:,1);
    raw_ecg = raw_ecg - mean(raw_ecg);

    % Resample to requested Fs and duration
    targetN = round(Fs*dur);
    raw_ecg = my_resample_vector(raw_ecg, targetN);
    t = (0:targetN-1)'/Fs;

    % Clean ECG morphology extracted from real data
    ecg_band = my_bandpass(raw_ecg, [0.5 40], Fs);
    ecg_clean = medfilt1(ecg_band, round(0.05*Fs));
    ecg_clean = ecg_clean / (max(abs(ecg_clean))+eps);

    % Motion artifact generation
    ma = zeros(targetN,1);
    for k=1:8
        c = rand*dur;
        w = 0.3 + 0.6*rand;
        idx = (t>=c & t<=c+w);
        lf = my_lowpass(randn(sum(idx),1), 6, Fs);
        ma(idx) = ma(idx) + (0.6+rand)*lf.*hann(sum(idx));
    end
    ma = my_lowpass(ma,6,Fs);

    % Power-line noise
    pli = 0.03*sin(2*pi*50*t);

    % Final noisy ECG
   % Nonstationary motion coupling
beta = 0.6 + 0.4*sin(2*pi*0.15*t + 2*pi*rand);

ecg_noisy = ecg_clean + beta.*ma + pli + 0.02*randn(targetN,1);


    % ACC from motion (physically correct reference)
   % Time-varying mixing between motion and ECG
mix = 0.3 + 0.7*sin(2*pi*0.2*t + 2*pi*rand);

acc = mix .* ma + 0.4*randn(targetN,1);
acc = my_lowpass(acc,6,Fs);

    acc = acc - mean(acc);
    acc = acc/(std(acc)+eps);
end


function y = my_gpulse(t, center, width)
    sigma = width/2.3548;
    y = exp(-(t-center).^2/(2*sigma^2));
end

function y = my_lowpass(x, fc, Fs)
    if fc <= 0 || fc >= Fs/2
        y = x; return;
    end
    [b,a] = butter(4, fc/(Fs/2));
    y = filtfilt(b,a,x);
end

function y = my_bandpass(x, band, Fs)
    f1 = band(1); f2 = band(2);
    if f1 <= 0, f1 = 0.01; end
    if f2 >= Fs/2, f2 = Fs/2-0.01; end
    [b,a] = butter(4, [f1 f2]/(Fs/2));
    y = filtfilt(b,a,x);
end

function [w_out, y, e] = my_lms_adaptive(d, x_ref, L, mu)
    N = length(d);
    w = zeros(L,1); y = zeros(N,1); e = zeros(N,1); xbuf = zeros(L,1);
    for n=1:N
        xbuf = [x_ref(n); xbuf(1:end-1)];
        y(n) = w'*xbuf;
        e(n) = d(n) - y(n);
        w = w + mu*e(n)*xbuf;
    end
    w_out = w;
end

function [y, w_out] = my_nlms_adaptive(d, x_ref, L, mu, eps_n)
    N = length(d);
    w = zeros(L,1); y = zeros(N,1); xbuf = zeros(L,1);
    for n=1:N
        xbuf = [x_ref(n); xbuf(1:end-1)];
        y(n) = w'*xbuf;
        e = d(n) - y(n);
        normx = xbuf'*xbuf + eps_n;
        w = w + (mu/normx)*e*xbuf;
    end
    w_out = w;
end

function [y, w_out] = my_pnlms_adaptive(d, x_ref, L, mu, rho, delta)
    N = length(d);
    w = zeros(L,1); y = zeros(N,1); xbuf = zeros(L,1);
    for n=1:N
        xbuf = [x_ref(n); xbuf(1:end-1)];
        y(n) = w'*xbuf;
        e = d(n) - y(n);
        absw = abs(w);
        maxw = max(absw);
        psi = max(delta, max(maxw, absw));
        g = psi / (mean(psi) + eps);
        G = diag(g + rho*ones(L,1));
        denom = xbuf'*(G*xbuf) + eps;
        w = w + (mu/denom) * G * xbuf * e;
    end
    w_out = w;
end

function [y, w_out] = my_ipnlms_adaptive(d, x_ref, L, mu, alpha, rho, delta)
    N = length(d);
    w = zeros(L,1); y = zeros(N,1); xbuf = zeros(L,1);
    for n=1:N
        xbuf = [x_ref(n); xbuf(1:end-1)];
        y(n) = w'*xbuf;
        e = d(n) - y(n);
        absw = abs(w);
        denom_w = sum(absw) + eps;
        gl = (1 - alpha)/(2*L) + (1 + alpha)*(absw)./(2*denom_w + eps);
        gl = max(gl, delta);
        g = gl / (mean(gl) + eps);
        G = diag(g + rho*ones(L,1));
        denom = xbuf'*(G*xbuf) + eps;
        w = w + (mu/denom) * G * xbuf * e;
    end
    w_out = w;
end

function [y, w_out] = my_rls_adaptive(d, x_ref, L, lambda, delta)
    N = length(d);
    w = zeros(L,1);
    P = (1/delta)*eye(L);
    y = zeros(N,1); xbuf = zeros(L,1);
    for n=1:N
        xbuf = [x_ref(n); xbuf(1:end-1)];
        y(n) = w'*xbuf;
        k = (P*xbuf) / (lambda + xbuf'*P*xbuf);
        e = d(n) - y(n);
        w = w + k*e;
        P = (P - k*xbuf'*P)/lambda;
    end
    w_out = w;
end

function [y, w_out] = my_kalman_adaptive(d, x_ref, L, q_var, r_var)
    N = length(d);
    w = zeros(L,1); P = eye(L)*1; Q = q_var*eye(L); R = r_var;
    y = zeros(N,1); xbuf = zeros(L,1);
    for n=1:N
        xbuf = [x_ref(n); xbuf(1:end-1)];
        P = P + Q;
        y(n) = w'*xbuf;
        S = xbuf'*P*xbuf + R;
        K = (P*xbuf)/S;
        e = d(n) - y(n);
        w = w + K*e;
        P = P - K*xbuf'*P;
    end
    w_out = w;
end

function y_out = my_simple_eemd_denoise(x_noisy, Fs, ensembles, noise_level)
    N = length(x_noisy);
    use_builtin = exist('emd','file')==2;
    recon_bank = zeros(N,ensembles);
    for k=1:ensembles
        wn = noise_level*randn(N,1);
        x_ens = x_noisy + wn;
        try
            if use_builtin
                imf = emd(x_ens);
                numIMF = size(imf,2);
                medfreqs = zeros(numIMF,1);
                for j=1:numIMF
                    Xf = abs(fft(imf(:,j)));
                    f = (0:N-1)*(Fs/N);
                    medfreqs(j) = sum(f'.*Xf)/(sum(Xf)+eps);
                end
                keep = medfreqs > 1.0;
                if any(keep)
                    recon = sum(imf(:,keep),2);
                else
                    recon = my_bandpass(x_ens, [0.5 40], Fs);
                end
            else
                recon = my_bandpass(x_ens, [0.5 40], Fs);
            end
        catch
            recon = my_bandpass(x_ens, [0.5 40], Fs);
        end
        recon_bank(:,k) = recon;
    end
    y_out = mean(recon_bank,2);
end
